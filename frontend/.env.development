# 后端 API 地址（本地开发默认 8000；若后端在其他机器请改成对应 IP:PORT）
# 示例: http://127.0.0.1:8000  或  http://192.168.1.20:8000
VITE_API_BASE_URL=http://127.0.0.1:8000

# 监控看板 - 扩展连接
# Kiali 地址（示例: http://192.168.1.20:20001）
VITE_EXT_LINK_KIALI=http://192.168.3.254:31523
# Grafana 地址（示例: http://192.168.1.20:3000）
VITE_EXT_LINK_GRAFANA=http://192.168.3.254:31765
# Prometheus 地址（示例: http://192.168.1.20:9090）
VITE_EXT_LINK_PROMETHEUS=http://192.168.3.254:32558
# Alertmanager 地址（示例: http://192.168.1.20:9093）
VITE_EXT_LINK_ALERTMANAGER=

